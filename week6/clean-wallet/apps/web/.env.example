# apps/web 환경변수 예시.
# 로컬: 이 파일을 .env.local 로 복사해 채운다. Amplify: 콘솔 Environment variables 에 설정.

# DynamoDB 테이블 이름. 미설정 시 in-memory(개발용, 비영속)로 폴백한다.
ARTIFACTS_TABLE=zcash-screening-artifacts

# AWS 리전. Amplify 는 자동 주입하므로 보통 생략. 로컬에선 명시.
AWS_REGION=us-east-1

# (선택) ingest API 보호 키. 설정하면 POST /api/artifacts 와 CLI --save 에
# x-api-key 헤더가 일치해야 한다. CLI 쪽도 동일 값을 INGEST_API_KEY 로 둔다.
# INGEST_API_KEY=change-me

# 로컬에서 실 DynamoDB 에 붙으려면 AWS 자격증명도 필요 (둘 중 하나):
#  1) aws configure 로 ~/.aws/credentials 프로파일, 또는
#  2) 아래 환경변수.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
