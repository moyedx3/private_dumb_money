# A1-a live chain-query target. Public endpoint; no secret is required for this step.
LIGHTWALLETD_URL=https://zec.rocks:443
# Optional fallback endpoint.
LIGHTWALLETD_BACKUP_URL=https://mainnet.lightwalletd.com:9067

# Optional range. If omitted, check-lightwalletd reads only the current tip block.
# A1_SCAN_START=3000000
# A1_SCAN_END=3000000

# Fetch the first tx referenced by the scanned compact block range using GetTransaction.
A1_FETCH_FIRST_TX=true

# Optional explicit full transaction fetch. Use normal explorer/display txid hex; the tool converts to lightwalletd byte order.
# A1_TXID_HEX=ae11a454...

RUST_LOG=info
